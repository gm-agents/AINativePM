---
interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  tags: string[];
  audience: string;
}

const { title, description, slug, pubDate, tags, audience } = Astro.props;

const audienceLabels: Record<string, string> = {
  all: 'All PMs',
  seasoned: 'Seasoned PMs',
  leaders: 'Senior Leaders',
  junior: 'Junior PMs',
  transitioning: 'Career Transitioners',
};

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/articles/${slug}`}
  class="group block border border-slate-200 rounded-2xl p-6 hover:border-brand-200 hover:bg-brand-50/30 transition-all duration-200"
>
  <div class="flex flex-wrap items-center gap-2 mb-3">
    <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-brand-50 text-brand-700">
      {audienceLabels[audience] || 'All PMs'}
    </span>
    {tags.slice(0, 2).map((tag) => (
      <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-slate-100 text-slate-600">
        {tag}
      </span>
    ))}
  </div>

  <h3 class="text-lg font-semibold text-slate-900 leading-snug mb-2 group-hover:text-brand-700 transition-colors">
    {title}
  </h3>
  <p class="text-sm text-slate-500 leading-relaxed line-clamp-2 mb-4">{description}</p>

  <div class="flex items-center justify-between">
    <span class="text-xs text-slate-400">{formattedDate}</span>
    <span class="text-xs font-medium text-brand-600 group-hover:translate-x-0.5 transition-transform inline-flex items-center gap-1">
      Read
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </span>
  </div>
</a>
