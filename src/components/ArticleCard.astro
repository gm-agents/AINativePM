---
interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  tags: string[];
  audience: string;
}

const { title, description, slug, pubDate, tags, audience } = Astro.props;

const audienceLabels: Record<string, string> = {
  all: 'All PMs',
  seasoned: 'Seasoned PMs',
  leaders: 'Senior Leaders',
  junior: 'Junior PMs',
  transitioning: 'Career Transitioners',
};

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/articles/${slug}`}
  class="card-warm group block bg-warm-50 border border-warm-200 rounded-2xl p-6 hover:border-brand-300 transition-all duration-250 flex flex-col h-full"
>
  <!-- Tags row -->
  <div class="flex flex-wrap items-center gap-2 mb-4">
    <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-brand-50 text-brand-700 border border-brand-100">
      {audienceLabels[audience] || 'All PMs'}
    </span>
    {tags.slice(0, 2).map((tag) => (
      <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-warm-100 text-stone-500 border border-warm-200">
        {tag}
      </span>
    ))}
  </div>

  <!-- Title -->
  <h3 class="font-serif-display text-xl text-stone-900 leading-snug mb-2 group-hover:text-brand-700 transition-colors">
    {title}
  </h3>

  <!-- Description -->
  <p class="text-sm text-stone-500 leading-relaxed line-clamp-2 mb-5 flex-1">{description}</p>

  <!-- Footer row -->
  <div class="flex items-center justify-between border-t border-warm-200 pt-4 mt-auto">
    <span class="text-xs text-warm-500 font-medium">{formattedDate}</span>
    <span class="text-xs font-bold text-brand-700 group-hover:translate-x-0.5 transition-transform inline-flex items-center gap-1">
      Read
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </span>
  </div>
</a>
