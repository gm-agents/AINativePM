---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-slate-100 bg-white">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <div class="w-7 h-7 rounded-md bg-blue-600 flex items-center justify-center">
            <span class="text-white text-xs font-bold">AI</span>
          </div>
          <span class="font-semibold text-slate-900 text-sm">AI Native Product Manager</span>
        </div>
        <p class="text-sm text-slate-500 max-w-xs">
          Practical thinking on Product Management in the age of AI.
        </p>
      </div>

      <!-- Links -->
      <div class="flex flex-col sm:items-end gap-4">
        <nav class="flex flex-wrap gap-x-6 gap-y-2">
          <a href="/articles" class="text-sm text-slate-500 hover:text-slate-900 transition-colors">Articles</a>
          <a href="/resources" class="text-sm text-slate-500 hover:text-slate-900 transition-colors">Resources</a>
          <a href="/about" class="text-sm text-slate-500 hover:text-slate-900 transition-colors">About</a>
          <span class="text-sm text-slate-400 cursor-not-allowed">Newsletter (Coming Soon)</span>
        </nav>
        <p class="text-xs text-slate-400">&copy; {currentYear} Girish Manghani. All rights reserved.</p>
      </div>
    </div>
  </div>
</footer>
