---
const pillars = [
  { href: '/ground-floor',  label: 'Ground Floor', color: 'bg-foundation-500', desc: 'PM fundamentals for those starting out' },
  { href: '/the-craft',     label: 'The Craft',    color: 'bg-craft-500',      desc: 'Timeless PM wisdom for every level' },
  { href: '/the-deep-end',  label: 'The Deep End', color: 'bg-depth-500',      desc: 'Senior & VP-level product leadership' },
  { href: '/ai-x-product',  label: 'AI × Product', color: 'bg-aix-500',        desc: 'AI-native product management' },
];

const navLinks = [
  { href: '/toolkit', label: 'The Toolkit' },
  { href: '/about',   label: 'About' },
];

const currentPath = Astro.url.pathname;

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="fixed top-0 inset-x-0 z-50 bg-warm-50/95 backdrop-blur-lg border-b border-warm-200">
  <nav class="max-w-6xl mx-auto px-6 h-[4.5rem] flex items-center justify-between gap-6">

    <!-- ── Logo / Masthead ── -->
    <a href="/" class="flex items-center gap-3 group flex-shrink-0">
      <div class="w-9 h-9 rounded-lg bg-brand-800 flex items-center justify-center shadow-sm flex-shrink-0">
        <span class="text-white text-xs font-extrabold tracking-tight">AI</span>
      </div>
      <div class="flex flex-col">
        <span class="font-serif-display text-[1.05rem] leading-none text-stone-900 group-hover:text-brand-700 transition-colors">
          AI Native PM
        </span>
        <span class="text-[10px] text-warm-500 leading-none mt-0.5 tracking-wide font-serif-display-italic">
          AI × Product thinking
        </span>
      </div>
    </a>

    <!-- ── Desktop Nav ── -->
    <div class="hidden lg:flex items-center gap-0.5">

      <!-- Explore dropdown -->
      <div class="relative group">
        <button
          class="nav-underline flex items-center gap-1.5 text-base font-semibold text-stone-600 hover:text-stone-900 px-4 py-2 rounded-lg hover:bg-warm-100 transition-colors"
        >
          Explore
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-warm-400 group-hover:text-stone-600 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <!-- Dropdown panel -->
        <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-200 absolute top-full left-1/2 -translate-x-1/2 pt-3 w-80">
          <div class="bg-warm-50 rounded-2xl shadow-xl border border-warm-200 p-2.5 space-y-0.5">
            <!-- Thin amber rule at top of dropdown -->
            <div class="h-px bg-gradient-to-r from-transparent via-craft-400 to-transparent mb-2.5 mx-3"></div>
            {pillars.map(({ href, label, color, desc }) => (
              <a
                href={href}
                class:list={[
                  'flex items-start gap-3 px-3 py-2.5 rounded-xl hover:bg-warm-100 transition-colors group/item',
                  isActive(href) ? 'bg-warm-100' : '',
                ]}
              >
                <span class={`w-2.5 h-2.5 rounded-full ${color} mt-1.5 flex-shrink-0`}></span>
                <div>
                  <span class="font-semibold text-sm text-stone-800 block group-hover/item:text-brand-700 transition-colors">{label}</span>
                  <span class="text-xs text-stone-500">{desc}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>

      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'nav-underline text-base font-semibold px-4 py-2 rounded-lg transition-colors',
            isActive(href)
              ? 'text-brand-700 bg-brand-50'
              : 'text-stone-600 hover:text-stone-900 hover:bg-warm-100',
          ]}
        >
          {label}
          {isActive(href) && (
            <span class="absolute -bottom-px left-0 w-full h-0.5 bg-brand-500 rounded-full"></span>
          )}
        </a>
      ))}
    </div>

    <!-- ── Desktop CTA ── -->
    <a
      href="/articles"
      class="hidden lg:inline-flex items-center gap-2 text-sm font-bold bg-brand-800 text-white px-5 py-2.5 rounded-xl hover:bg-brand-900 transition-all hover:shadow-md hover:ring-2 hover:ring-craft-400/40 hover:ring-offset-1"
    >
      All Articles
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>

    <!-- ── Mobile Menu Button ── -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden p-2 text-stone-600 hover:text-stone-900 rounded-lg hover:bg-warm-100 transition-colors"
      aria-label="Toggle menu"
    >
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- ── Mobile Menu ── -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-warm-200 bg-warm-50 px-6 py-6">
    <p class="text-xs font-bold uppercase tracking-widest text-warm-500 mb-3">Explore</p>
    <div class="space-y-1 mb-6">
      {pillars.map(({ href, label, color }) => (
        <a href={href} class="flex items-center gap-3 text-base font-semibold text-stone-700 hover:text-stone-900 px-3 py-2.5 rounded-xl hover:bg-warm-100 transition-colors">
          <span class={`w-2 h-2 rounded-full ${color}`}></span>
          {label}
        </a>
      ))}
    </div>
    <div class="border-t border-warm-200 pt-5 space-y-1 mb-5">
      {navLinks.map(({ href, label }) => (
        <a href={href} class="block text-base font-semibold text-stone-700 hover:text-stone-900 px-3 py-2.5 rounded-xl hover:bg-warm-100 transition-colors">
          {label}
        </a>
      ))}
    </div>
    <a
      href="/articles"
      class="flex items-center justify-center gap-2 text-sm font-bold bg-brand-800 text-white px-4 py-3 rounded-xl hover:bg-brand-900 transition-colors"
    >
      All Articles
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</header>

<script>
  const btn     = document.getElementById('mobile-menu-btn');
  const menu    = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
