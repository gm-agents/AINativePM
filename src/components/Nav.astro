---
const navLinks = [
  { href: '/articles', label: 'Articles' },
  { href: '/wisdom', label: "Lenny's Wisdom" },
  { href: '/resources', label: 'Resources' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 inset-x-0 z-50 bg-white/90 backdrop-blur-sm border-b border-slate-100">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-7 h-7 rounded-md bg-blue-600 flex items-center justify-center">
        <span class="text-white text-xs font-bold">AI</span>
      </div>
      <span class="font-semibold text-slate-900 text-sm">
        AI Native PM
      </span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden sm:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'text-sm font-medium transition-colors',
            currentPath.startsWith(href)
              ? 'text-slate-900'
              : 'text-slate-500 hover:text-slate-900',
          ]}
        >
          {label}
        </a>
      ))}
    </div>

    <!-- CTA -->
    <span class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium bg-slate-200 text-slate-400 px-4 py-2 rounded-lg cursor-not-allowed">
      Coming Soon
    </span>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="sm:hidden p-2 text-slate-600"
      aria-label="Toggle menu"
    >
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-slate-100 bg-white px-6 py-4 flex flex-col gap-4">
    {navLinks.map(({ href, label }) => (
      <a href={href} class="text-sm font-medium text-slate-700">{label}</a>
    ))}
    <span class="inline-flex justify-center text-sm font-medium bg-slate-200 text-slate-400 px-4 py-2 rounded-lg cursor-not-allowed">
      Newsletter Coming Soon
    </span>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
