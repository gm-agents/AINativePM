---
import type { WisdomItem } from '../data/wisdom';

interface Props {
  item: WisdomItem;
  index?: number;
}

const { item, index = 0 } = Astro.props;

const audienceColor =
  item.audience === 'starting-out'
    ? { bg: 'bg-emerald-50', border: 'border-emerald-200', badge: 'bg-emerald-100 text-emerald-700', quote: 'text-emerald-700' }
    : { bg: 'bg-brand-50', border: 'border-brand-200', badge: 'bg-brand-100 text-brand-700', quote: 'text-brand-700' };
---

<article
  class={`rounded-2xl border ${audienceColor.bg} ${audienceColor.border} p-6 flex flex-col gap-4 hover:shadow-md transition-shadow duration-200`}
>
  <!-- Quote mark + quote -->
  <div class="flex gap-3">
    <span class={`text-4xl leading-none font-serif ${audienceColor.quote} select-none mt-1`}>&ldquo;</span>
    <blockquote class="text-slate-800 font-medium text-base leading-relaxed">
      {item.quote}
    </blockquote>
  </div>

  <!-- Insight -->
  <p class="text-slate-600 text-sm leading-relaxed border-t border-slate-200 pt-4">
    <span class="font-semibold text-slate-700">Why it matters: </span>{item.insight}
  </p>

  <!-- Tags -->
  <div class="flex flex-wrap gap-2">
    {item.tags.map((tag) => (
      <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${audienceColor.badge}`}>
        {tag}
      </span>
    ))}
  </div>

  <!-- Guest info -->
  <div class="flex items-start gap-3 mt-auto pt-4 border-t border-slate-200">
    <div class={`w-9 h-9 rounded-full flex items-center justify-center text-white text-sm font-bold flex-shrink-0 ${item.audience === 'starting-out' ? 'bg-emerald-500' : 'bg-brand-600'}`}>
      {item.guest.charAt(0)}
    </div>
    <div class="min-w-0">
      <p class="font-semibold text-slate-800 text-sm truncate">{item.guest}</p>
      <p class="text-slate-500 text-xs leading-snug">{item.guestTitle}</p>
      <p class="text-slate-400 text-xs mt-0.5 italic truncate">{item.episodeTitle}</p>
    </div>
  </div>
</article>
