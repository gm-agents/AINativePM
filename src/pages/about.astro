---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const building = [
  {
    title: 'AI Learnings Repository',
    description: 'A growing collection of lessons, frameworks, and hard-won insights on building AI-native products, from evals to LLM-powered features that actually ship.',
    icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    borderColor: 'border-aix-200',
    iconBg: 'bg-aix-50',
    iconColor: 'text-aix-600',
    badge: 'bg-aix-100 text-aix-700',
  },
  {
    title: 'PM Frameworks Library',
    description: 'Battle-tested frameworks from real product work, not textbook theory. Prioritisation, discovery, strategy, and the hard stuff in between.',
    icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10',
    borderColor: 'border-craft-200',
    iconBg: 'bg-craft-50',
    iconColor: 'text-craft-600',
    badge: 'bg-craft-100 text-craft-700',
  },
  {
    title: 'Community',
    description: 'A space for AI-native PMs to learn together: share what you are building, get feedback, and find peers navigating the same transition.',
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
    borderColor: 'border-foundation-200',
    iconBg: 'bg-foundation-50',
    iconColor: 'text-foundation-600',
    badge: 'bg-foundation-100 text-foundation-700',
  },
];
---

<Base
  title="About | AI Native PM"
  description="Product leader, AI enthusiast, and the mind behind AI Native PM. Writing about the craft of product management in the AI era."
>
  <Nav />

  <main class="pt-[4.5rem] bg-warm-50">

    <!-- ── HERO ── -->
    <section class="bg-warm-100 border-b border-warm-200">
      <div class="max-w-4xl mx-auto px-6 py-16 sm:py-24 flex flex-col items-center text-center">

        <!-- Avatar -->
        <div class="w-24 h-24 rounded-full bg-brand-100 flex items-center justify-center mb-7 ring-4 ring-brand-50 shadow-sm">
          <span class="font-serif-display text-brand-700 text-2xl select-none">GM</span>
        </div>

        <div class="flex items-center gap-3 mb-4">
          <div class="h-px w-8 bg-craft-400"></div>
          <p class="text-xs font-bold uppercase tracking-widest text-warm-500">About</p>
          <div class="h-px w-8 bg-craft-400"></div>
        </div>
        <h1 class="font-serif-display text-4xl sm:text-5xl text-stone-900 mb-4 leading-tight tracking-tight">
          Behind AI Native PM
        </h1>
        <div class="w-14 h-1 bg-craft-400 rounded-full mb-5 mx-auto"></div>
        <p class="text-lg text-stone-500 max-w-xl leading-relaxed">
          Product leader, AI enthusiast, and the mind behind this site.
        </p>

      </div>
    </section>

    <!-- ── BIO ── -->
    <section class="py-16">
      <div class="max-w-3xl mx-auto px-6">

        <div class="text-lg text-stone-600 leading-relaxed space-y-6">
          <p>
            I have spent the last decade working in and around product: shipping consumer apps and everything in between. I have sat in the roadmap reviews, run the discovery sprints, wrestled with stakeholders, and shipped the features that flopped as much as the ones that found their audience. Product management is the strangest job in tech, and I love it.
          </p>
          <p>
            About one year ago, AI stopped being a feature I was scoping and started being a shift I was living through. The models started actually working. The tools started actually mattering. And the question I kept asking — and kept getting asked — was: <em class="font-serif-display-italic text-stone-800">what does it mean to be a great PM now?</em> Not in the abstract. In practice, on Monday morning, with a real team and real constraints.
          </p>
          <p>
            AI Native PM is my attempt to answer that question publicly. Not a think-piece operation, not a hype machine. Just honest, practical writing about product management as the craft is being remade in real time. I write for the PM who is mid-career and wondering whether their skills still translate. For the new PM trying to learn a craft that is still being defined. And for anyone who suspects that the way we have always built products is probably not how we will build them five years from now.
          </p>
          <p>
            I am building a repository of learnings and lessons on AI-native product management, along with a frameworks library and eventually a community — all of which you can read more about below. If you find the writing useful, joining the newsletter is the best way to stay in the loop.
          </p>
        </div>

        <!-- Connect -->
        <div class="mt-12 pt-10 border-t border-warm-200">
          <p class="text-sm font-bold text-stone-700 mb-4">Let's connect</p>
          <div class="flex flex-wrap gap-3">
            <a
              href="https://www.linkedin.com/in/girish-manghani"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 border border-warm-300 bg-warm-100 text-stone-700 hover:text-brand-700 hover:border-brand-300 font-semibold text-sm px-5 py-2.5 rounded-xl transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          </div>
        </div>

      </div>
    </section>

    <!-- ── WHAT I'M BUILDING ── -->
    <section class="py-16 px-6 bg-warm-100 border-t border-warm-200">
      <div class="max-w-4xl mx-auto">

        <div class="text-center mb-12 animate-on-scroll">
          <div class="flex items-center justify-center gap-3 mb-4">
            <div class="h-px w-8 bg-craft-400"></div>
            <p class="text-xs font-bold uppercase tracking-widest text-warm-500">On the horizon</p>
            <div class="h-px w-8 bg-craft-400"></div>
          </div>
          <h2 class="font-serif-display text-2xl sm:text-3xl text-stone-900 mb-3">What's in the Works</h2>
          <div class="w-12 h-1 bg-craft-400 rounded-full mx-auto mb-5"></div>
          <p class="text-stone-500 max-w-xl mx-auto leading-relaxed">
            Beyond the writing, here's what is being built for AI Native PM.
          </p>
        </div>

        <div class="grid sm:grid-cols-3 gap-5 stagger-children">
          {building.map(({ title, description, icon, borderColor, iconBg, iconColor, badge }) => (
            <div class={`card-warm relative bg-warm-50 rounded-2xl border ${borderColor} p-7 transition-all duration-200 animate-on-scroll`}>
              <span class={`absolute top-5 right-5 text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full ${badge}`}>
                Coming soon
              </span>
              <div class={`w-11 h-11 rounded-xl flex items-center justify-center mb-5 ${iconBg}`}>
                <svg xmlns="http://www.w3.org/2000/svg" class={`w-5 h-5 ${iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
                </svg>
              </div>
              <h3 class="font-serif-display text-lg text-stone-900 mb-2 pr-20">{title}</h3>
              <p class="text-stone-500 text-sm leading-relaxed">{description}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ── FEEDBACK ── -->
    <section class="py-16 px-6 bg-warm-50 border-t border-warm-200">
      <div class="max-w-2xl mx-auto">

        <div class="text-center mb-10">
          <div class="flex items-center justify-center gap-3 mb-4">
            <div class="h-px w-8 bg-craft-400"></div>
            <p class="text-xs font-bold uppercase tracking-widest text-warm-500">Get in touch</p>
            <div class="h-px w-8 bg-craft-400"></div>
          </div>
          <h2 class="font-serif-display text-2xl sm:text-3xl text-stone-900 mb-3">Send Feedback or Suggestions</h2>
          <div class="w-12 h-1 bg-craft-400 rounded-full mx-auto mb-5"></div>
          <p class="text-stone-500 leading-relaxed">
            Something missing? A topic you'd love covered? A framework that changed how you think? I read everything.
          </p>
        </div>

        <form id="feedback-form" class="space-y-5">
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="fb-name" class="block text-sm font-semibold text-stone-700 mb-1.5">Your name <span class="text-warm-400 font-normal">(optional)</span></label>
              <input
                id="fb-name" name="name" type="text" placeholder="e.g. Alex"
                class="w-full rounded-xl border border-warm-300 bg-warm-100 px-4 py-2.5 text-sm text-stone-900 placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-brand-400 transition"
              />
            </div>
            <div>
              <label for="fb-email" class="block text-sm font-semibold text-stone-700 mb-1.5">Your email <span class="text-warm-400 font-normal">(optional)</span></label>
              <input
                id="fb-email" name="email" type="email" placeholder="you@example.com"
                class="w-full rounded-xl border border-warm-300 bg-warm-100 px-4 py-2.5 text-sm text-stone-900 placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-brand-400 transition"
              />
            </div>
          </div>

          <div>
            <label for="fb-type" class="block text-sm font-semibold text-stone-700 mb-1.5">Type</label>
            <select
              id="fb-type" name="type"
              class="w-full rounded-xl border border-warm-300 bg-warm-100 px-4 py-2.5 text-sm text-stone-900 focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-brand-400 transition"
            >
              <option value="Feedback">Feedback on existing content</option>
              <option value="Suggestion">Topic suggestion</option>
              <option value="Framework">Framework or resource recommendation</option>
              <option value="Other">Something else</option>
            </select>
          </div>

          <div>
            <label for="fb-message" class="block text-sm font-semibold text-stone-700 mb-1.5">Message <span class="text-red-400">*</span></label>
            <textarea
              id="fb-message" name="message" rows="5" required placeholder="What's on your mind?"
              class="w-full rounded-xl border border-warm-300 bg-warm-100 px-4 py-2.5 text-sm text-stone-900 placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-brand-400 transition resize-none"
            ></textarea>
          </div>

          <div id="fb-success" class="hidden rounded-xl bg-foundation-50 border border-foundation-200 px-5 py-4 text-foundation-700 text-sm font-medium">
            Thanks for reaching out! I'll get back to you if a reply makes sense.
          </div>
          <div id="fb-error" class="hidden rounded-xl bg-red-50 border border-red-200 px-5 py-4 text-red-700 text-sm">
            Something went wrong. Please try again or reach out on LinkedIn.
          </div>

          <button
            type="submit" id="fb-submit"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-brand-800 text-white font-bold text-sm px-7 py-3 rounded-xl hover:bg-brand-900 transition-colors disabled:opacity-50 disabled:cursor-not-allowed hover:ring-2 hover:ring-craft-400/40 hover:ring-offset-1"
          >
            <span id="fb-btn-text">Send Message</span>
            <svg id="fb-spinner" class="hidden w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
            </svg>
          </button>
        </form>

      </div>
    </section>

    <!-- ── NEWSLETTER CTA ── -->
    <section class="bg-brand-900 py-14 px-6">
      <div class="max-w-2xl mx-auto text-center">
        <h3 class="font-serif-display text-2xl sm:text-3xl text-white mb-3">Stay in the loop</h3>
        <p class="text-brand-200 mb-7 leading-relaxed">
          New articles, framework drops, and course updates — straight to your inbox. No spam.
        </p>
        <a href="/#newsletter" class="inline-block bg-white text-brand-800 font-bold px-8 py-3.5 rounded-xl hover:bg-warm-100 transition-colors">
          Join the Newsletter
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Base>

<script>
  const form      = document.getElementById('feedback-form') as HTMLFormElement;
  const submitBtn = document.getElementById('fb-submit') as HTMLButtonElement;
  const btnText   = document.getElementById('fb-btn-text') as HTMLSpanElement;
  const spinner   = document.getElementById('fb-spinner') as HTMLElement;
  const successMsg = document.getElementById('fb-success') as HTMLElement;
  const errorMsg   = document.getElementById('fb-error') as HTMLElement;

  const FORMSPREE_ENDPOINT = 'https://formspree.io/f/mvzvajag';

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const message = (document.getElementById('fb-message') as HTMLTextAreaElement).value.trim();
    if (!message) return;

    submitBtn.disabled = true;
    btnText.textContent = 'Sending...';
    spinner.classList.remove('hidden');
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    const data = new FormData(form);

    try {
      const res = await fetch(FORMSPREE_ENDPOINT, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        form.reset();
        successMsg.classList.remove('hidden');
      } else {
        errorMsg.classList.remove('hidden');
      }
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      btnText.textContent = 'Send Message';
      spinner.classList.add('hidden');
    }
  });
</script>
