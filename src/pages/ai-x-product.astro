---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const articles = allArticles
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Base
  title="AI × Product | AI-Native PM | AI Native PM"
  description="AI-native product management: from evals and prompt engineering to building with LLMs. Courses, frameworks, and hard-won lessons from the frontier."
>
  <Nav />

  <main class="pt-[4.5rem] bg-warm-50">

    <!-- Hero -->
    <section class="bg-warm-100 border-b border-warm-200">
      <div class="max-w-6xl mx-auto px-6 pt-14 pb-12">
        <div class="flex items-center gap-3 mb-5">
          <div class="h-px w-8 bg-aix-400"></div>
          <span class="w-2.5 h-2.5 rounded-full bg-aix-500"></span>
          <span class="text-aix-600 font-bold text-xs uppercase tracking-widest">AI × Product</span>
        </div>
        <h1 class="font-serif-display text-4xl sm:text-5xl lg:text-6xl text-stone-900 mb-4 leading-tight tracking-tight">
          Build the future.
        </h1>
        <div class="w-14 h-1 bg-aix-400 rounded-full mb-5"></div>
        <p class="text-lg text-stone-500 max-w-2xl leading-relaxed">
          AI-native product management: from evals and prompt engineering to building with LLMs. My courses, frameworks, and hard-won lessons from shipping real AI products. This is the frontier.
        </p>
      </div>
    </section>

    <!-- Coming Soon banner -->
    <section class="max-w-6xl mx-auto px-6 pt-12 pb-2">
      <div class="relative overflow-hidden border-2 border-dashed border-aix-300 bg-aix-50 rounded-2xl px-8 py-8 flex flex-col sm:flex-row sm:items-center gap-5">
        <div class="flex-1">
          <p class="text-aix-600 font-bold text-xs uppercase tracking-widest mb-2">Coming Soon</p>
          <h2 class="font-serif-display text-xl text-stone-900 mb-2">Courses, videos &amp; frameworks: in progress</h2>
          <p class="text-stone-500 text-sm leading-relaxed max-w-xl">
            A full curriculum for AI-native PMs is on the way: structured courses, video walkthroughs, eval frameworks, prompt libraries, and real case studies from building with LLMs. Sign up to be the first to know when it drops.
          </p>
        </div>
        <div class="flex-shrink-0">
          <span class="inline-flex items-center gap-2 bg-aix-100 text-aix-700 font-semibold text-sm px-5 py-2.5 rounded-xl border border-aix-200">
            <span class="w-2 h-2 rounded-full bg-aix-500 animate-pulse"></span>
            In development
          </span>
        </div>
      </div>
    </section>

    <!-- Articles -->
    <section class="max-w-6xl mx-auto px-6 py-12">
      {articles.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 stagger-children">
          {articles.map((article) => (
            <div class="animate-on-scroll">
              <ArticleCard
                title={article.data.title}
                description={article.data.description}
                slug={article.slug}
                pubDate={article.data.pubDate}
                tags={article.data.tags}
                audience={article.data.audience}
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <div class="inline-block border border-aix-200 bg-aix-50 rounded-2xl px-8 py-10">
            <span class="w-3 h-3 rounded-full bg-aix-500 inline-block mb-4"></span>
            <p class="text-aix-600 font-bold text-sm uppercase tracking-widest mb-2">Coming Soon</p>
            <p class="text-stone-400 text-lg">Content coming soon.</p>
          </div>
        </div>
      )}
    </section>

  </main>

  <Footer />
</Base>
