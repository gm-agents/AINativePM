---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const sorted = allArticles.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const audienceFilters = [
  { value: 'all',          label: 'All' },
  { value: 'seasoned',     label: 'Seasoned PMs' },
  { value: 'leaders',      label: 'Senior Leaders' },
  { value: 'junior',       label: 'Junior PMs' },
  { value: 'transitioning', label: 'Career Transitioners' },
];
---

<Base
  title="Articles | AI Native PM"
  description="All articles on Product Management in the age of AI: strategy, decision-making, career guidance, and more."
>
  <Nav />

  <main class="pt-[4.5rem] bg-warm-50">

    <!-- ── HERO ── -->
    <section class="bg-warm-100 border-b border-warm-200">
      <div class="max-w-4xl mx-auto px-6 py-14 sm:py-20">
        <div class="flex items-center gap-3 mb-5">
          <div class="h-px w-8 bg-craft-400"></div>
          <p class="text-xs font-bold uppercase tracking-widest text-warm-500">Articles</p>
        </div>
        <h1 class="font-serif-display text-4xl sm:text-5xl text-stone-900 mb-4 leading-tight tracking-tight">
          All Articles
        </h1>
        <div class="w-14 h-1 bg-craft-400 rounded-full mb-5"></div>
        <p class="text-stone-500 text-lg max-w-xl leading-relaxed">
          Thinking on product management, AI strategy, leadership, and careers — for every stage of the journey.
        </p>
      </div>
    </section>

    <div class="max-w-6xl mx-auto px-6 py-14">

      <!-- Filter Tabs -->
      <div class="flex flex-wrap gap-2 mb-10" id="filter-tabs">
        {audienceFilters.map(({ value, label }) => (
          <button
            data-filter={value}
            class:list={[
              'filter-btn text-sm font-semibold px-4 py-2 rounded-full border transition-colors',
              value === 'all'
                ? 'bg-brand-800 text-white border-brand-800'
                : 'bg-warm-50 text-stone-600 border-warm-300 hover:border-stone-400 hover:text-stone-900',
            ]}
          >
            {label}
          </button>
        ))}
      </div>

      <!-- Articles Grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5" id="articles-grid">
        {sorted.map((article) => (
          <div data-audience={article.data.audience} class="article-item animate-on-scroll">
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              slug={article.slug}
              pubDate={article.data.pubDate}
              tags={article.data.tags}
              audience={article.data.audience}
            />
          </div>
        ))}
      </div>

    </div>
  </main>

  <Footer />
</Base>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items   = document.querySelectorAll<HTMLElement>('.article-item');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      buttons.forEach((b) => {
        b.classList.remove('bg-brand-800', 'text-white', 'border-brand-800');
        b.classList.add('bg-warm-50', 'text-stone-600', 'border-warm-300');
      });
      btn.classList.add('bg-brand-800', 'text-white', 'border-brand-800');
      btn.classList.remove('bg-warm-50', 'text-stone-600', 'border-warm-300');

      items.forEach((item) => {
        if (filter === 'all' || item.dataset.audience === filter || item.dataset.audience === 'all') {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });
</script>
