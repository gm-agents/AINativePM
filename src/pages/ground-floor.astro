---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const articles = allArticles
  .filter((a) => ['junior', 'transitioning', 'all'].includes(a.data.audience))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Base
  title="Ground Floor | PM Fundamentals | AI Native PM"
  description="Build your PM foundation from first principles. Guides and frameworks for new PMs and career transitioners breaking into product management."
>
  <Nav />

  <main class="pt-16">
    <!-- Hero -->
    <section class="bg-white border-b border-slate-200">
      <div class="max-w-6xl mx-auto px-6 pt-16 pb-12">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-3 h-3 rounded-full bg-foundation-500"></span>
          <span class="text-foundation-600 font-semibold text-xs uppercase tracking-widest">Ground Floor</span>
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-4">
          Build your PM foundation.
        </h1>
        <p class="text-lg text-slate-500 max-w-2xl leading-relaxed">
          For new PMs, career transitioners, and anyone who wants to understand the craft from first principles. No fluff, just the real skills you need to break in and grow fast.
        </p>
      </div>
    </section>

    <!-- Articles -->
    <section class="max-w-6xl mx-auto px-6 py-16">
      {articles.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {articles.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              slug={article.slug}
              pubDate={article.data.pubDate}
              tags={article.data.tags}
              audience={article.data.audience}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <div class="inline-block border border-foundation-200 bg-foundation-50 rounded-2xl px-8 py-10">
            <span class="w-3 h-3 rounded-full bg-foundation-500 inline-block mb-4"></span>
            <p class="text-foundation-600 font-semibold text-sm uppercase tracking-widest mb-2">Coming Soon</p>
            <p class="text-slate-400 text-lg">Content coming soon.</p>
          </div>
        </div>
      )}
    </section>
  </main>

  <Footer />
</Base>
