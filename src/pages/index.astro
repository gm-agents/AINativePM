---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const featuredArticles = allArticles
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const audiences = [
  {
    label: 'Seasoned PMs',
    icon: '◈',
    description:
      'Stay ahead of the curve. Deep dives on AI strategy, product decision-making, and how to evolve your craft as the discipline transforms around you.',
  },
  {
    label: 'Senior Leaders',
    icon: '◇',
    description:
      'Build AI-ready product organizations. Frameworks for structuring teams, setting strategy, and leading through the ambiguity of an AI-first landscape.',
  },
  {
    label: 'Junior PMs',
    icon: '○',
    description:
      'Build the right foundation. Practical skills, mental models, and career guidance designed for the AI era — not the decade that came before it.',
  },
  {
    label: 'Career Transitioners',
    icon: '△',
    description:
      'Make the move intelligently. How to leverage your domain expertise, position your experience, and land your first PM role in an AI-first world.',
  },
];
---

<Base title="AI Native Product Manager">
  <Nav />

  <main class="pt-16">
    <!-- Hero -->
    <section class="max-w-6xl mx-auto px-6 pt-20 pb-24">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-blue-600 mb-6">
          <span class="w-5 h-px bg-blue-600"></span>
          Product Management · AI · Strategy
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 leading-[1.1] tracking-tight mb-6">
          Product Management<br />
          in the Age of&nbsp;AI.
        </h1>
        <p class="text-lg sm:text-xl text-slate-500 leading-relaxed max-w-2xl mb-10">
          Practical thinking for product managers navigating the AI revolution — whether you're a seasoned leader, just starting out, or making the move into the field.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/articles"
            class="inline-flex items-center gap-2 bg-blue-600 text-white font-medium px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors"
          >
            Read Articles
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <span class="inline-flex items-center gap-2 border border-slate-200 text-slate-400 font-medium px-6 py-3 rounded-lg cursor-not-allowed">
            Newsletter Coming Soon
          </span>
        </div>
      </div>
    </section>

    <!-- Who This Is For -->
    <section class="bg-slate-50 border-y border-slate-100">
      <div class="max-w-6xl mx-auto px-6 py-20">
        <div class="mb-12">
          <p class="text-xs font-semibold uppercase tracking-widest text-blue-600 mb-3">Who this is for</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-slate-900">
            Whatever stage you're at, there's something here for you.
          </h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {audiences.map(({ label, icon, description }) => (
            <div class="bg-white border border-slate-200 rounded-2xl p-6 flex flex-col gap-4">
              <span class="text-2xl text-slate-400">{icon}</span>
              <div>
                <h3 class="font-semibold text-slate-900 mb-2">{label}</h3>
                <p class="text-sm text-slate-500 leading-relaxed">{description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Latest Articles -->
    <section class="max-w-6xl mx-auto px-6 py-20">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-blue-600 mb-3">Latest</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-slate-900">Recent Articles</h2>
        </div>
        <a
          href="/articles"
          class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors"
        >
          View all
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {featuredArticles.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            slug={article.slug}
            pubDate={article.data.pubDate}
            tags={article.data.tags}
            audience={article.data.audience}
          />
        ))}
      </div>
      <div class="mt-6 sm:hidden text-center">
        <a
          href="/articles"
          class="text-sm font-medium text-blue-600 hover:text-blue-700"
        >
          View all articles →
        </a>
      </div>
    </section>

    <!-- Newsletter CTA -->
    <section class="max-w-6xl mx-auto px-6 pb-24">
      <div class="bg-blue-600 rounded-3xl px-8 py-14 sm:px-16 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
        <div class="max-w-xl">
          <p class="text-blue-200 text-sm font-semibold uppercase tracking-widest mb-3">Free Newsletter</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-white leading-snug mb-3">
            Stay sharp on AI and Product Management.
          </h2>
          <p class="text-blue-100 leading-relaxed">
            New articles, frameworks, and thinking delivered to your inbox. No noise, no spam — just signal.
          </p>
        </div>
        <div class="flex-shrink-0">
          <span class="inline-flex items-center gap-2 bg-white/20 text-white/60 font-semibold px-6 py-3 rounded-lg cursor-not-allowed whitespace-nowrap">
            Newsletter Coming Soon
          </span>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
