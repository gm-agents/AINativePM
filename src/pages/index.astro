---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const featuredArticles = allArticles
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const pillars = [
  {
    href: '/ground-floor',
    label: 'Ground Floor',
    tagline: 'Build your foundation',
    description: 'For new PMs, career transitioners, and anyone who wants to understand the craft from first principles. No fluff, just the real skills.',
    color: 'foundation',
    dot: 'bg-foundation-500',
    iconPath: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1',
  },
  {
    href: '/the-craft',
    label: 'The Craft',
    tagline: 'Sharpen your practice',
    description: 'Timeless product wisdom for every level: discovery, prioritisation, communication, and the day-to-day art of shipping great products.',
    color: 'craft',
    dot: 'bg-craft-500',
    iconPath: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  },
  {
    href: '/the-deep-end',
    label: 'The Deep End',
    tagline: 'Lead with clarity',
    description: 'Strategy, org design, executive communication, and the hard decisions only senior PMs and VP+ leaders face. No hand-holding here.',
    color: 'depth',
    dot: 'bg-depth-500',
    iconPath: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    href: '/ai-x-product',
    label: 'AI × Product',
    tagline: 'Build the future',
    description: 'AI-native product management: from evals and prompt engineering to building with LLMs. My courses, frameworks, and hard-won lessons.',
    color: 'aix',
    dot: 'bg-aix-500',
    iconPath: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  },
];
---

<Base title="AI Native Product Manager | Product thinking for every stage of your career">
  <Nav />

  <main class="pt-[4.5rem]">

    <!-- ── HERO ─────────────────────────────────────────────────────────── -->
    <section class="relative overflow-hidden bg-warm-50 bg-dots">
      <!-- Warm amber glow top-right -->
      <div class="absolute top-0 right-0 w-[480px] h-[480px] bg-craft-200/30 rounded-full blur-3xl pointer-events-none"></div>
      <!-- Indigo glow bottom-left -->
      <div class="absolute bottom-0 left-0 w-[360px] h-[360px] bg-brand-200/20 rounded-full blur-3xl pointer-events-none"></div>

      <div class="relative max-w-6xl mx-auto px-6 pt-24 pb-16 sm:pt-32 sm:pb-24">

        <!-- Thin decorative rule -->
        <div class="flex items-center gap-4 mb-10">
          <div class="h-px w-10 bg-craft-400"></div>
          <div class="flex items-center gap-2.5">
            <span class="w-2 h-2 rounded-full bg-foundation-400 animate-pulse-slow"></span>
            <span class="w-2 h-2 rounded-full bg-craft-400 animate-pulse-slow" style="animation-delay: 0.3s"></span>
            <span class="w-2 h-2 rounded-full bg-depth-400 animate-pulse-slow" style="animation-delay: 0.6s"></span>
            <span class="w-2 h-2 rounded-full bg-aix-400 animate-pulse-slow" style="animation-delay: 0.9s"></span>
          </div>
          <div class="h-px flex-1 bg-warm-200"></div>
        </div>

        <div class="max-w-3xl">
          <h1 class="font-serif-display text-5xl sm:text-6xl lg:text-7xl text-stone-900 leading-[1.05] mb-6 tracking-tight">
            Product thinking for<br />
            <span class="font-serif-display-italic text-brand-700">every stage</span>
            <span class="text-stone-900"> of your career.</span>
          </h1>

          <!-- Amber underline accent below the headline -->
          <div class="w-20 h-1 bg-craft-400 rounded-full mb-8"></div>

          <p class="text-xl text-stone-500 leading-relaxed max-w-2xl mb-10">
            Whether you're breaking into PM, sharpening your craft, leading at scale, or building with AI —
            <span class="text-stone-700 font-medium">there's a path here for you.</span>
          </p>

          <div class="flex flex-wrap gap-3">
            <a
              href="#pillars"
              class="inline-flex items-center gap-2 bg-brand-800 text-white font-bold px-7 py-3.5 rounded-xl hover:bg-brand-900 transition-all hover:shadow-lg hover:ring-2 hover:ring-craft-400/40 hover:ring-offset-2"
            >
              Start exploring
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
              </svg>
            </a>
            <a
              href="/articles"
              class="inline-flex items-center gap-2 bg-warm-100 border border-warm-300 text-stone-700 font-semibold px-7 py-3.5 rounded-xl hover:bg-warm-200 hover:border-warm-400 transition-all"
            >
              Browse all articles
            </a>
          </div>
        </div>
      </div>

      <!-- Bottom fade to section below -->
      <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-warm-100/60 to-transparent pointer-events-none"></div>
    </section>

    <!-- ── FOUR PILLARS ───────────────────────────────────────────────── -->
    <section id="pillars" class="bg-warm-100 border-y border-warm-200 scroll-mt-20">
      <div class="max-w-6xl mx-auto px-6 py-16 sm:py-20">

        <div class="flex items-center gap-4 mb-10 animate-on-scroll">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-warm-500 mb-1">Where do you want to grow?</p>
            <h2 class="font-serif-display text-2xl sm:text-3xl text-stone-900">Four paths. One destination.</h2>
          </div>
          <div class="flex-1 h-px bg-warm-300 hidden sm:block"></div>
        </div>

        <div class="grid sm:grid-cols-2 gap-5 stagger-children">
          {pillars.map(({ href, label, tagline, description, color, dot, iconPath }) => (
            <a
              href={href}
              class={`card-warm group relative bg-warm-50 rounded-2xl border border-warm-200 p-7 hover:border-${color}-300 transition-all duration-300 flex flex-col gap-4 animate-on-scroll`}
            >
              <div class="flex items-start justify-between">
                <div class={`w-11 h-11 rounded-xl bg-${color}-100 flex items-center justify-center`}>
                  <svg xmlns="http://www.w3.org/2000/svg" class={`w-5 h-5 text-${color}-600`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconPath} />
                  </svg>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-warm-300 group-hover:text-stone-500 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>

              <div>
                <h3 class="font-serif-display text-xl text-stone-900 mb-0.5 group-hover:text-brand-700 transition-colors">{label}</h3>
                <p class={`text-sm font-semibold text-${color}-600 mb-2`}>{tagline}</p>
                <p class="text-sm text-stone-500 leading-relaxed">{description}</p>
              </div>

              <!-- Bottom colour accent bar -->
              <div class={`h-0.5 w-10 rounded-full bg-${color}-400 group-hover:w-20 transition-all duration-300 mt-auto`}></div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── LATEST ARTICLES ────────────────────────────────────────────── -->
    <section class="bg-warm-50 border-b border-warm-200">
      <div class="max-w-6xl mx-auto px-6 py-20">

        <div class="flex items-end justify-between mb-10 animate-on-scroll">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-warm-500 mb-2">Fresh off the press</p>
            <h2 class="font-serif-display text-2xl sm:text-3xl text-stone-900">Latest Articles</h2>
          </div>
          <a
            href="/articles"
            class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700 hover:text-brand-900 transition-colors nav-underline"
          >
            View all
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 stagger-children">
          {featuredArticles.map((article) => (
            <div class="animate-on-scroll">
              <ArticleCard
                title={article.data.title}
                description={article.data.description}
                slug={article.slug}
                pubDate={article.data.pubDate}
                tags={article.data.tags}
                audience={article.data.audience}
              />
            </div>
          ))}
        </div>

        <div class="mt-6 sm:hidden text-center">
          <a href="/articles" class="text-sm font-semibold text-brand-700 hover:text-brand-900">
            View all articles &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- ── TOOLKIT TEASER ─────────────────────────────────────────────── -->
    <section class="max-w-6xl mx-auto px-6 py-20 animate-on-scroll">
      <div class="relative overflow-hidden bg-warm-100 rounded-3xl border border-warm-300 p-10 sm:p-14 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
        <!-- Decorative dots pattern in corner -->
        <div class="absolute top-0 right-0 w-48 h-48 bg-dots opacity-60 pointer-events-none"></div>
        <!-- Amber accent line at top -->
        <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-craft-400 via-craft-300 to-transparent rounded-t-3xl"></div>

        <div class="max-w-lg relative">
          <p class="text-xs font-bold uppercase tracking-widest text-warm-500 mb-3">Curated for you</p>
          <h2 class="font-serif-display text-2xl sm:text-3xl text-stone-900 mb-3">The Toolkit</h2>
          <p class="text-stone-600 leading-relaxed">
            Everything you need in one place: Lenny's Podcast wisdom, recommended training, people to follow, the best PM blogs, podcasts, and more.
          </p>
        </div>

        <a
          href="/toolkit"
          class="inline-flex items-center gap-2 bg-brand-800 text-white font-bold px-7 py-3.5 rounded-xl hover:bg-brand-900 transition-all hover:shadow-md hover:ring-2 hover:ring-craft-400/40 hover:ring-offset-1 flex-shrink-0"
        >
          Open the Toolkit
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Base>
