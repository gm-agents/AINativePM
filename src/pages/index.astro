---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const featuredArticles = allArticles
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const pillars = [
  {
    href: '/ground-floor',
    label: 'Ground Floor',
    tagline: 'Build your foundation',
    description: 'For new PMs, career transitioners, and anyone who wants to understand the craft from first principles. No fluff, just the real skills.',
    color: 'foundation',
    iconPath: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1',
  },
  {
    href: '/the-craft',
    label: 'The Craft',
    tagline: 'Sharpen your practice',
    description: 'Timeless product wisdom for every level: discovery, prioritisation, communication, and the day-to-day art of shipping great products.',
    color: 'craft',
    iconPath: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  },
  {
    href: '/the-deep-end',
    label: 'The Deep End',
    tagline: 'Lead with clarity',
    description: 'Strategy, org design, executive communication, and the hard decisions only senior PMs and VP+ leaders face. No hand-holding here.',
    color: 'depth',
    iconPath: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    href: '/ai-x-product',
    label: 'AI \u00d7 Product',
    tagline: 'Build the future',
    description: 'AI-native product management: from evals and prompt engineering to building with LLMs. My courses, frameworks, and hard-won lessons.',
    color: 'aix',
    iconPath: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  },
];
---

<Base title="AI Native Product Manager | Product thinking for every stage of your career">
  <Nav />

  <main class="pt-16">
    <!-- ── HERO ──────────────────────────────────────────────────── -->
    <section class="relative overflow-hidden bg-brand-950">
      <!-- Subtle gradient orbs -->
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-brand-600/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-aix-500/15 rounded-full blur-3xl"></div>

      <div class="relative max-w-6xl mx-auto px-6 pt-24 pb-20 sm:pt-32 sm:pb-28">
        <div class="max-w-3xl">
          <div class="flex items-center gap-3 mb-8">
            <span class="w-2.5 h-2.5 rounded-full bg-foundation-400 animate-pulse"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-craft-400 animate-pulse" style="animation-delay: 0.2s"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-depth-400 animate-pulse" style="animation-delay: 0.4s"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-aix-400 animate-pulse" style="animation-delay: 0.6s"></span>
          </div>

          <h1 class="font-serif-display text-4xl sm:text-5xl lg:text-6xl text-white leading-[1.1] mb-6">
            Product thinking for<br />
            <span class="text-brand-300">every stage of your career.</span>
          </h1>

          <p class="text-lg sm:text-xl text-slate-400 leading-relaxed max-w-2xl mb-10">
            Whether you're breaking into PM, sharpening your craft, leading at scale, or building with AI. There's a path here for you.
          </p>

          <div class="flex flex-wrap gap-3">
            <a
              href="#pillars"
              class="inline-flex items-center gap-2 bg-white text-brand-900 font-semibold px-6 py-3 rounded-xl hover:bg-brand-50 transition-colors"
            >
              Start exploring
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
              </svg>
            </a>
            <a
              href="/articles"
              class="inline-flex items-center gap-2 bg-white/10 border border-white/20 text-white font-semibold px-6 py-3 rounded-xl hover:bg-white/20 transition-colors"
            >
              Browse all articles
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── FOUR PILLARS ─────────────────────────────────────────── -->
    <section id="pillars" class="max-w-6xl mx-auto px-6 -mt-10 relative z-10 pb-20 scroll-mt-20">
      <div class="grid sm:grid-cols-2 gap-4">
        {pillars.map(({ href, label, tagline, description, color, iconPath }) => (
          <a
            href={href}
            class={`group relative bg-white rounded-2xl border border-slate-200 p-6 sm:p-8 hover:shadow-lg hover:border-${color}-300 transition-all duration-300 flex flex-col gap-4`}
          >
            <div class="flex items-start justify-between">
              <div class={`w-11 h-11 rounded-xl bg-${color}-100 flex items-center justify-center`}>
                <svg xmlns="http://www.w3.org/2000/svg" class={`w-5 h-5 text-${color}-600`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconPath} />
                </svg>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-300 group-hover:text-slate-500 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>

            <div>
              <h3 class="font-bold text-lg text-slate-900 mb-1">{label}</h3>
              <p class={`text-sm font-medium text-${color}-600 mb-2`}>{tagline}</p>
              <p class="text-sm text-slate-500 leading-relaxed">{description}</p>
            </div>

            <!-- Bottom colour accent bar -->
            <div class={`h-1 w-12 rounded-full bg-${color}-400 group-hover:w-20 transition-all duration-300 mt-auto`}></div>
          </a>
        ))}
      </div>
    </section>

    <!-- ── LATEST ARTICLES ──────────────────────────────────────── -->
    <section class="bg-white border-y border-slate-200">
      <div class="max-w-6xl mx-auto px-6 py-20">
        <div class="flex items-end justify-between mb-10">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-brand-600 mb-3">Fresh off the press</p>
            <h2 class="text-2xl sm:text-3xl font-bold text-slate-900">Latest Articles</h2>
          </div>
          <a
            href="/articles"
            class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-brand-600 hover:text-brand-700 transition-colors"
          >
            View all
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {featuredArticles.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              slug={article.slug}
              pubDate={article.data.pubDate}
              tags={article.data.tags}
              audience={article.data.audience}
            />
          ))}
        </div>
        <div class="mt-6 sm:hidden text-center">
          <a href="/articles" class="text-sm font-medium text-brand-600 hover:text-brand-700">
            View all articles &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- ── TOOLKIT TEASER ───────────────────────────────────────── -->
    <section class="max-w-6xl mx-auto px-6 py-20">
      <div class="bg-gradient-to-br from-brand-50 to-slate-50 rounded-3xl border border-brand-100 p-8 sm:p-12 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
        <div class="max-w-lg">
          <p class="text-xs font-semibold uppercase tracking-widest text-brand-600 mb-3">Curated for you</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-3">The Toolkit</h2>
          <p class="text-slate-600 leading-relaxed">
            Everything you need in one place: Lenny's Podcast wisdom, recommended training, people to follow, the best PM blogs, podcasts, and more.
          </p>
        </div>
        <a
          href="/toolkit"
          class="inline-flex items-center gap-2 bg-brand-700 text-white font-semibold px-6 py-3 rounded-xl hover:bg-brand-800 transition-colors shadow-sm flex-shrink-0"
        >
          Open the Toolkit
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Base>
