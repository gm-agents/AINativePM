---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Resources"
  description="Curated resources for product managers navigating the age of AI — books, tools, frameworks, and more. Coming soon."
>
  <Nav />

  <main class="pt-16">
    <div class="max-w-3xl mx-auto px-6 py-24">

      <p class="text-xs font-semibold uppercase tracking-widest text-blue-600 mb-6">Resources</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">
        Curated Resources
      </h1>
      <p class="text-lg text-slate-500 leading-relaxed mb-14 max-w-xl">
        A hand-picked collection of books, tools, frameworks, podcasts, and communities for product managers working in the age of AI. Coming soon.
      </p>

      <!-- Coming Soon Cards -->
      <div class="grid sm:grid-cols-2 gap-4 mb-16">
        {[
          { category: 'Books', description: 'Essential reading on AI, strategy, and product craft.' },
          { category: 'Tools', description: 'AI tools that belong in every PM\'s workflow.' },
          { category: 'Frameworks', description: 'Mental models for building in an AI-first world.' },
          { category: 'Communities', description: 'Where the best AI PMs gather and share ideas.' },
        ].map(({ category, description }) => (
          <div class="border border-dashed border-slate-200 rounded-2xl p-6 bg-slate-50 opacity-60">
            <div class="w-8 h-8 rounded-md bg-slate-200 mb-4"></div>
            <h3 class="font-semibold text-slate-700 mb-1">{category}</h3>
            <p class="text-sm text-slate-400">{description}</p>
          </div>
        ))}
      </div>

      <!-- Newsletter Nudge -->
      <div class="border border-slate-200 rounded-2xl p-8 bg-white">
        <p class="text-xs font-semibold uppercase tracking-widest text-blue-600 mb-3">Get notified</p>
        <h2 class="text-xl font-bold text-slate-900 mb-2">Be first to know when Resources launches</h2>
        <p class="text-slate-600 mb-6">
          Subscribe to the newsletter and you'll hear about it the moment it's live — along with new articles every week.
        </p>
        <span class="inline-flex items-center gap-2 bg-slate-200 text-slate-400 font-medium px-5 py-2.5 rounded-lg cursor-not-allowed text-sm">
          Newsletter Coming Soon
        </span>
      </div>
    </div>
  </main>

  <Footer />
</Base>
