---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const articles = allArticles
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Base
  title="The Craft — Timeless PM Wisdom | AI Native PM"
  description="Timeless product wisdom for every PM level — discovery, prioritisation, communication, and the day-to-day art of shipping great products."
>
  <Nav />

  <main class="pt-16">
    <!-- Hero -->
    <section class="bg-white border-b border-slate-200">
      <div class="max-w-6xl mx-auto px-6 pt-16 pb-12">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-3 h-3 rounded-full bg-craft-500"></span>
          <span class="text-craft-600 font-semibold text-xs uppercase tracking-widest">The Craft</span>
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-4">
          Sharpen your practice.
        </h1>
        <p class="text-lg text-slate-500 max-w-2xl leading-relaxed">
          Timeless product wisdom for every level — discovery, prioritisation, stakeholder communication, and the day-to-day art of shipping great products. No matter where you are in your career, this is for you.
        </p>
      </div>
    </section>

    <!-- Articles -->
    <section class="max-w-6xl mx-auto px-6 py-16">
      {articles.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {articles.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              slug={article.slug}
              pubDate={article.data.pubDate}
              tags={article.data.tags}
              audience={article.data.audience}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <div class="inline-block border border-craft-200 bg-craft-50 rounded-2xl px-8 py-10">
            <span class="w-3 h-3 rounded-full bg-craft-500 inline-block mb-4"></span>
            <p class="text-craft-600 font-semibold text-sm uppercase tracking-widest mb-2">Coming Soon</p>
            <p class="text-slate-400 text-lg">Content coming soon.</p>
          </div>
        </div>
      )}
    </section>
  </main>

  <Footer />
</Base>
