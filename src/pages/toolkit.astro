---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WisdomCard from '../components/WisdomCard.astro';
import { startingOutWisdom, seasonedWisdom } from '../data/wisdom';

const tabs = [
  { href: '#lennys-wisdom', label: "Lenny's Wisdom" },
  { href: '#training',      label: 'Training' },
  { href: '#people',        label: 'People to Follow' },
  { href: '#blogs',         label: 'Blogs' },
  { href: '#podcasts',      label: 'Podcasts' },
];

const trainings = [
  {
    name: 'Reforge',
    url: 'reforge.com',
    href: 'https://www.reforge.com',
    description: 'Product strategy and growth programs',
  },
  {
    name: "Lenny's Newsletter",
    url: 'lennysnewsletter.com',
    href: 'https://www.lennysnewsletter.com',
    description: 'Weekly product management insights',
  },
  {
    name: 'SVPG',
    url: 'svpg.com',
    href: 'https://www.svpg.com',
    description: 'Inspired product team frameworks',
  },
  {
    name: 'Product School',
    url: 'productschool.com',
    href: 'https://www.productschool.com',
    description: 'PM certifications and courses',
  },
];

const people = [
  {
    name: 'Shreyas Doshi',
    handle: '@shreyas',
    description: 'Product frameworks and mental models',
  },
  {
    name: 'Lenny Rachitsky',
    handle: '@lennysan',
    description: 'The #1 PM newsletter and podcast',
  },
  {
    name: 'Julie Zhuo',
    handle: '@joulee',
    description: 'Design and product leadership',
  },
  {
    name: 'Gibson Biddle',
    handle: '@gibsonbiddle',
    description: 'Product strategy masterclass',
  },
  {
    name: 'Elena Verna',
    handle: '@elenaverna',
    description: 'Growth and PLG strategy',
  },
  {
    name: 'Marty Cagan',
    handle: '@caborom',
    description: 'Empowered product teams',
  },
];

const blogs = [
  {
    name: 'Stratechery',
    author: 'Ben Thompson',
    description: 'Sharp analysis of tech strategy and the business of technology — essential reading for anyone who thinks about product and markets.',
  },
  {
    name: "Lenny's Newsletter",
    author: 'Lenny Rachitsky',
    description: 'Deep dives on product, growth, and career from one of the most respected voices in product management.',
  },
  {
    name: 'The Beautiful Mess',
    author: 'John Cutler',
    description: 'Thoughtful, nuanced takes on product work, organisational dynamics, and the messy reality of building things.',
  },
  {
    name: 'Department of Product',
    author: 'Various',
    description: 'Practical resources, case studies, and frameworks for product managers at every level.',
  },
  {
    name: 'Mind the Product',
    author: 'Various',
    description: 'A community-driven publication with articles, conference talks, and career resources for PMs worldwide.',
  },
];

const podcasts = [
  {
    name: "Lenny's Podcast",
    host: 'Lenny Rachitsky',
    description: 'In-depth conversations with world-class product leaders on what it really takes to build great products.',
  },
  {
    name: 'The Product Podcast',
    host: 'Product School',
    description: 'Interviews with senior PMs and CPOs sharing hard-won lessons from real product work.',
  },
  {
    name: 'Intercom on Product',
    host: 'Intercom',
    description: 'Short, sharp episodes on product strategy, design, and engineering from the Intercom team.',
  },
  {
    name: 'Masters of Scale',
    host: 'Reid Hoffman',
    description: 'How great founders and leaders scaled their companies — packed with strategic frameworks for ambitious builders.',
  },
  {
    name: 'How I Built This',
    host: 'Guy Raz · NPR',
    description: 'The stories behind iconic companies, told by the founders who built them from scratch.',
  },
];
---

<Base
  title="The Toolkit — Resources for Product Managers | AI Native PM"
  description="Curated resources for product managers — training programs, people to follow, blogs, podcasts, and wisdom from the world's best PMs."
>
  <Nav />

  <main class="pt-16">

    <!-- ── HERO ──────────────────────────────────────────────────────────── -->
    <section class="bg-white border-b border-slate-200">
      <div class="max-w-4xl mx-auto px-6 py-14 sm:py-20 text-center">
        <p class="text-xs font-semibold uppercase tracking-widest text-brand-600 mb-4">Resources</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 mb-4 leading-tight">
          The Toolkit
        </h1>
        <p class="text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          A curated collection of the best resources for product managers — from Lenny's wisdom to the training programs, people, blogs, and podcasts that will sharpen your thinking.
        </p>
      </div>
    </section>

    <!-- ── STICKY TAB BAR ─────────────────────────────────────────────────── -->
    <div class="sticky top-16 z-40 bg-white border-b border-slate-200">
      <div class="max-w-6xl mx-auto px-6">
        <nav class="flex items-center gap-1 overflow-x-auto scrollbar-none -mb-px py-0">
          {tabs.map(({ href, label }) => (
            <a
              href={href}
              class="flex-shrink-0 text-sm font-medium text-slate-500 hover:text-slate-900 px-4 py-4 border-b-2 border-transparent hover:border-slate-300 transition-colors whitespace-nowrap"
            >
              {label}
            </a>
          ))}
        </nav>
      </div>
    </div>

    <!-- ── LENNY'S WISDOM ─────────────────────────────────────────────────── -->
    <section id="lennys-wisdom" class="py-16 px-6 scroll-mt-20 bg-slate-50">
      <div class="max-w-6xl mx-auto">

        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-widest text-brand-600 mb-2">Curated insights</p>
          <h2 class="text-2xl font-bold text-slate-900 mb-2">Lenny's Wisdom</h2>
          <p class="text-slate-500 max-w-2xl leading-relaxed">
            The best quotes and insights from Lenny Rachitsky's conversations with the world's top product leaders — organised by where you are in your PM journey.
          </p>
        </div>

        <!-- For Those Starting Out -->
        <div class="mb-14">
          <div class="flex items-center gap-3 mb-6">
            <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 flex-shrink-0"></span>
            <h3 class="text-lg font-semibold text-slate-800">For Those Starting Out</h3>
            <span class="text-xs bg-emerald-100 text-emerald-700 font-medium px-2.5 py-0.5 rounded-full">
              {startingOutWisdom.length} insights
            </span>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {startingOutWisdom.map((item, i) => (
              <WisdomCard item={item} index={i} />
            ))}
          </div>
        </div>

        <!-- For Seasoned PMs -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <span class="w-2.5 h-2.5 rounded-full bg-brand-600 flex-shrink-0"></span>
            <h3 class="text-lg font-semibold text-slate-800">For Seasoned PMs</h3>
            <span class="text-xs bg-brand-100 text-brand-700 font-medium px-2.5 py-0.5 rounded-full">
              {seasonedWisdom.length} insights
            </span>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {seasonedWisdom.map((item, i) => (
              <WisdomCard item={item} index={i} />
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- ── TRAINING ────────────────────────────────────────────────────────── -->
    <section id="training" class="py-16 px-6 scroll-mt-20 bg-white">
      <div class="max-w-6xl mx-auto">

        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-widest text-brand-600 mb-2">Level up</p>
          <h2 class="text-2xl font-bold text-slate-900 mb-2">Training</h2>
          <p class="text-slate-500 max-w-2xl leading-relaxed">
            The programs, courses, and newsletters that the best PMs in the world recommend for developing your craft.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          {trainings.map(({ name, url, href, description }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="group bg-white rounded-2xl border border-slate-200 p-6 hover:shadow-md hover:border-brand-200 transition-all duration-200"
            >
              <p class="font-semibold text-slate-900 mb-1 group-hover:text-brand-700 transition-colors">{name}</p>
              <p class="text-brand-600 text-xs mb-3">{url}</p>
              <p class="text-slate-500 text-sm leading-relaxed">{description}</p>
            </a>
          ))}
        </div>

      </div>
    </section>

    <!-- ── PEOPLE TO FOLLOW ───────────────────────────────────────────────── -->
    <section id="people" class="py-16 px-6 scroll-mt-20 bg-slate-50">
      <div class="max-w-6xl mx-auto">

        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-widest text-brand-600 mb-2">The signal</p>
          <h2 class="text-2xl font-bold text-slate-900 mb-2">People to Follow</h2>
          <p class="text-slate-500 max-w-2xl leading-relaxed">
            The product thinkers whose writing, threads, and talks consistently raise your game.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {people.map(({ name, handle, description }) => (
            <div class="bg-white rounded-2xl border border-slate-200 p-5 hover:shadow-md hover:border-brand-200 transition-all duration-200">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 rounded-full bg-brand-100 text-brand-700 font-bold flex items-center justify-center flex-shrink-0 text-sm">
                  {name.charAt(0)}
                </div>
                <div>
                  <p class="font-semibold text-slate-900 text-sm leading-tight">{name}</p>
                  <p class="text-slate-400 text-xs mt-0.5">{handle}</p>
                </div>
              </div>
              <p class="text-slate-500 text-sm leading-relaxed">{description}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ── BLOGS ──────────────────────────────────────────────────────────── -->
    <section id="blogs" class="py-16 px-6 scroll-mt-20 bg-white">
      <div class="max-w-6xl mx-auto">

        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-widest text-brand-600 mb-2">Long-form reading</p>
          <h2 class="text-2xl font-bold text-slate-900 mb-2">Blogs</h2>
          <p class="text-slate-500 max-w-2xl leading-relaxed">
            Publications worth adding to your reading list — consistently high signal, low noise.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          {blogs.map(({ name, author, description }) => (
            <div class="bg-white rounded-2xl border border-slate-200 p-6 hover:shadow-md hover:border-brand-200 transition-all duration-200">
              <div class="flex items-start justify-between gap-3 mb-2">
                <p class="font-semibold text-slate-900">{name}</p>
                <span class="text-xs text-slate-400 flex-shrink-0 mt-0.5">by {author}</span>
              </div>
              <p class="text-slate-500 text-sm leading-relaxed">{description}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ── PODCASTS ───────────────────────────────────────────────────────── -->
    <section id="podcasts" class="py-16 px-6 scroll-mt-20 bg-slate-50">
      <div class="max-w-6xl mx-auto">

        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-widest text-brand-600 mb-2">Ears-on learning</p>
          <h2 class="text-2xl font-bold text-slate-900 mb-2">Podcasts</h2>
          <p class="text-slate-500 max-w-2xl leading-relaxed">
            Put these on during your commute, workout, or afternoon walk — they compound quietly over time.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          {podcasts.map(({ name, host, description }) => (
            <div class="bg-white rounded-2xl border border-slate-200 p-6 hover:shadow-md hover:border-brand-200 transition-all duration-200">
              <div class="flex items-start justify-between gap-3 mb-2">
                <p class="font-semibold text-slate-900">{name}</p>
                <span class="text-xs text-slate-400 flex-shrink-0 mt-0.5">{host}</span>
              </div>
              <p class="text-slate-500 text-sm leading-relaxed">{description}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ── CTA ────────────────────────────────────────────────────────────── -->
    <section class="bg-brand-600 py-14 px-6">
      <div class="max-w-2xl mx-auto text-center">
        <h3 class="text-2xl font-bold text-white mb-3">Want more PM insights?</h3>
        <p class="text-brand-100 mb-6 leading-relaxed">
          Get weekly articles on AI-native product management — from strategy to execution to surviving the AI transition.
        </p>
        <a
          href="/#newsletter"
          class="inline-block bg-white text-brand-700 font-semibold px-7 py-3 rounded-xl hover:bg-brand-50 transition-colors"
        >
          Join the Newsletter
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Base>
