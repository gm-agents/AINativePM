---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ToolkitNav from '../../components/ToolkitNav.astro';

const blogs = [
  {
    name: 'Stratechery',
    author: 'Ben Thompson',
    url: 'stratechery.com',
    href: 'https://www.stratechery.com',
    description: "Sharp analysis of tech strategy and the business of technology. Essential reading for anyone who thinks about product and markets. Ben's Aggregation Theory alone is worth the subscription.",
    tags: ['Strategy', 'Tech Business', 'Paid'],
  },
  {
    name: "Lenny's Newsletter",
    author: 'Lenny Rachitsky',
    url: 'lennysnewsletter.com',
    href: 'https://www.lennysnewsletter.com',
    description: 'Deep dives on product, growth, and career from one of the most respected voices in PM. Backed by data from thousands of PM survey responses. Weekly, with a large archive of evergreen content.',
    tags: ['Product', 'Growth', 'Career', 'Weekly'],
  },
  {
    name: 'The Beautiful Mess',
    author: 'John Cutler',
    url: 'cutlefish.substack.com',
    href: 'https://cutlefish.substack.com',
    description: "Thoughtful, nuanced takes on product work, organisational dynamics, and the messy reality of building things. John writes about the dimensions most product writing glosses over — the human and systemic side.",
    tags: ['Org Design', 'Systems', 'Nuance'],
  },
  {
    name: 'Department of Product',
    author: 'Various',
    url: 'departmentofproduct.com',
    href: 'https://www.departmentofproduct.com',
    description: 'Practical resources, case studies, and frameworks for product managers at every level. Good for templates, job prep, and tactical PM skills.',
    tags: ['Practical', 'Frameworks', 'Career'],
  },
  {
    name: 'Mind the Product',
    author: 'Various',
    url: 'mindtheproduct.com',
    href: 'https://www.mindtheproduct.com',
    description: 'A community-driven publication with articles, conference talks, and career resources for PMs worldwide. One of the largest PM communities online — good for breadth and discovery.',
    tags: ['Community', 'Conference', 'Global'],
  },
];
---

<Base
  title="Blogs — The Toolkit | AI Native PM"
  description="Publications worth adding to your reading list — consistently high signal, low noise."
>
  <Nav />
  <ToolkitNav active="/toolkit/blogs" />

  <main class="pt-[4.5rem] bg-warm-50">

    <!-- ── HERO ── -->
    <section class="bg-warm-100 border-b border-warm-200">
      <div class="max-w-4xl mx-auto px-6 py-12 sm:py-16">
        <div class="flex items-center gap-3 mb-5">
          <div class="h-px w-8 bg-craft-400"></div>
          <p class="text-xs font-bold uppercase tracking-widest text-warm-500">Long-form reading</p>
        </div>
        <h1 class="font-serif-display text-3xl sm:text-4xl text-stone-900 mb-4 leading-tight tracking-tight">
          Blogs
        </h1>
        <div class="w-14 h-1 bg-craft-400 rounded-full mb-5"></div>
        <p class="text-lg text-stone-500 max-w-2xl leading-relaxed">
          Publications worth adding to your reading list — consistently high signal, low noise.
        </p>
      </div>
    </section>

    <div class="py-16 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="grid gap-5 stagger-children">
          {blogs.map(({ name, author, url, href, description, tags }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="card-warm group bg-warm-50 rounded-2xl border border-warm-200 p-7 hover:border-brand-300 transition-all duration-200 flex flex-col gap-4 animate-on-scroll"
            >
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="font-serif-display text-xl text-stone-900 mb-0.5 group-hover:text-brand-700 transition-colors">{name}</p>
                  <p class="text-stone-500 text-sm">by {author} · <span class="text-brand-600 font-medium">{url}</span></p>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-warm-300 group-hover:text-brand-500 transition-colors flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </div>
              <p class="text-stone-600 leading-relaxed">{description}</p>
              <div class="flex flex-wrap gap-2 pt-1">
                {tags.map((tag) => (
                  <span class="text-xs bg-warm-100 text-stone-500 font-semibold px-2.5 py-1 rounded-full border border-warm-200">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- ── SECTION NAV ── -->
    <div class="bg-warm-100 border-t border-warm-200 py-8 px-6">
      <div class="max-w-6xl mx-auto flex justify-between">
        <a href="/toolkit/people" class="flex items-center gap-2 text-sm font-bold text-stone-500 hover:text-stone-900 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          People to Follow
        </a>
        <a href="/toolkit/podcasts" class="flex items-center gap-2 text-sm font-bold text-brand-700 hover:text-brand-900 transition-colors">
          Next: Podcasts
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>

  </main>

  <Footer />
</Base>
