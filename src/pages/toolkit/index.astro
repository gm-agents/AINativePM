---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const sections = [
  {
    href: '/toolkit/lennys-wisdom',
    label: "Lenny's Wisdom",
    tagline: 'Curated insights',
    description: "The best quotes and insights from Lenny Rachitsky's conversations with the world's top product leaders, organised by where you are in your PM journey.",
    icon: '💡',
    count: '16 insights',
    border: 'border-brand-200 hover:border-brand-400',
    bg: 'bg-warm-50',
    badge: 'bg-brand-50 text-brand-700',
  },
  {
    href: '/toolkit/training',
    label: 'Training',
    tagline: 'Level up',
    description: 'The programs, courses, and newsletters that the best PMs in the world recommend for developing your craft.',
    icon: '🎓',
    count: '4 resources',
    border: 'border-foundation-200 hover:border-foundation-400',
    bg: 'bg-warm-50',
    badge: 'bg-foundation-100 text-foundation-700',
  },
  {
    href: '/toolkit/people',
    label: 'People to Follow',
    tagline: 'The signal',
    description: 'The product thinkers whose writing, threads, and talks consistently raise your game.',
    icon: '🧠',
    count: '6 people',
    border: 'border-craft-200 hover:border-craft-400',
    bg: 'bg-warm-50',
    badge: 'bg-craft-100 text-craft-700',
  },
  {
    href: '/toolkit/blogs',
    label: 'Blogs',
    tagline: 'Long-form reading',
    description: 'Publications worth adding to your reading list — consistently high signal, low noise.',
    icon: '📖',
    count: '5 blogs',
    border: 'border-depth-200 hover:border-depth-400',
    bg: 'bg-warm-50',
    badge: 'bg-depth-100 text-depth-700',
  },
  {
    href: '/toolkit/podcasts',
    label: 'Podcasts',
    tagline: 'Ears-on learning',
    description: 'Put these on during your commute, workout, or afternoon walk — they compound quietly over time.',
    icon: '🎙️',
    count: '5 podcasts',
    border: 'border-aix-200 hover:border-aix-400',
    bg: 'bg-warm-50',
    badge: 'bg-aix-100 text-aix-700',
  },
];
---

<Base
  title="The Toolkit — Resources for Product Managers | AI Native PM"
  description="Curated resources for product managers: Lenny's wisdom, training programs, people to follow, blogs, and podcasts."
>
  <Nav />

  <main class="pt-[4.5rem] bg-warm-50">

    <!-- ── HERO ── -->
    <section class="bg-warm-100 border-b border-warm-200">
      <div class="max-w-4xl mx-auto px-6 py-14 sm:py-20">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-px w-8 bg-craft-400"></div>
          <p class="text-xs font-bold uppercase tracking-widest text-warm-500">Resources</p>
        </div>
        <h1 class="font-serif-display text-4xl sm:text-5xl text-stone-900 mb-4 leading-tight tracking-tight">
          The Toolkit
        </h1>
        <div class="w-14 h-1 bg-craft-400 rounded-full mb-6"></div>
        <p class="text-lg text-stone-500 max-w-2xl leading-relaxed">
          A curated collection of the best resources for product managers — from Lenny's wisdom to training programs, people, blogs, and podcasts that sharpen your thinking.
        </p>
      </div>
    </section>

    <!-- ── SECTION CARDS ── -->
    <section class="py-16 px-6 bg-warm-50">
      <div class="max-w-5xl mx-auto">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 stagger-children">
          {sections.map(({ href, label, tagline, description, icon, count, border, bg, badge }) => (
            <a
              href={href}
              class={`card-warm group rounded-2xl border-2 ${border} ${bg} p-7 transition-all duration-200 flex flex-col gap-4 animate-on-scroll`}
            >
              <div class="flex items-start justify-between gap-3">
                <span class="text-3xl">{icon}</span>
                <span class={`text-xs font-semibold px-2.5 py-1 rounded-full border border-warm-200 ${badge}`}>{count}</span>
              </div>
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-warm-500 mb-1">{tagline}</p>
                <h2 class="font-serif-display text-xl text-stone-900 mb-2 group-hover:text-brand-700 transition-colors">{label}</h2>
                <p class="text-stone-500 text-sm leading-relaxed">{description}</p>
              </div>
              <div class="mt-auto flex items-center gap-1.5 text-sm font-bold text-brand-700 group-hover:text-brand-900 transition-colors">
                Explore
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="bg-brand-900 py-14 px-6">
      <div class="max-w-2xl mx-auto text-center">
        <h3 class="font-serif-display text-2xl sm:text-3xl text-white mb-3">Want more PM insights?</h3>
        <p class="text-brand-200 mb-7 leading-relaxed">
          Get weekly articles on AI-native product management, from strategy to execution to surviving the AI transition.
        </p>
        <a href="/#newsletter" class="inline-block bg-white text-brand-800 font-bold px-8 py-3.5 rounded-xl hover:bg-warm-100 transition-colors hover:ring-2 hover:ring-craft-400/40 hover:ring-offset-2">
          Join the Newsletter
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Base>
