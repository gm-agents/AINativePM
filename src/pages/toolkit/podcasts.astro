---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ToolkitNav from '../../components/ToolkitNav.astro';

const podcasts = [
  {
    name: "Lenny's Podcast",
    host: 'Lenny Rachitsky',
    frequency: 'Weekly',
    description: 'In-depth conversations with world-class product leaders on what it really takes to build great products. The best consistently-produced PM podcast running. Guests include CPOs and founders from the most respected companies in tech.',
    bestFor: 'All PM levels — an evergreen listen.',
    tags: ['Product', 'Career', 'Weekly'],
  },
  {
    name: 'The Product Podcast',
    host: 'Product School',
    frequency: 'Weekly',
    description: 'Interviews with senior PMs and CPOs sharing hard-won lessons from real product work. Broad guest list means a wide range of industries, company sizes, and PM specialisations.',
    bestFor: 'PMs looking for diverse perspectives and practical advice.',
    tags: ['Interviews', 'Practical', 'Weekly'],
  },
  {
    name: 'Intercom on Product',
    host: 'Intercom',
    frequency: 'Irregular',
    description: 'Short, sharp episodes on product strategy, design, and engineering from the Intercom product team. Concise and high-density — you can get through an episode on a short commute.',
    bestFor: 'B2B PMs and those who want to think about product strategy through a customer success lens.',
    tags: ['B2B', 'Strategy', 'Short episodes'],
  },
  {
    name: 'Masters of Scale',
    host: 'Reid Hoffman',
    frequency: 'Weekly',
    description: "How great founders and leaders scaled their companies, packed with strategic frameworks for ambitious builders. Reid's Socratic interview style surfaces counter-intuitive lessons that don't surface elsewhere.",
    bestFor: 'Senior PMs and those thinking about company-level strategy.',
    tags: ['Scaling', 'Founders', 'Leadership'],
  },
  {
    name: 'How I Built This',
    host: 'Guy Raz · NPR',
    frequency: 'Weekly',
    description: 'The stories behind iconic companies, told by the founders who built them from scratch. Less tactical than PM-specific shows, but invaluable for building conviction and understanding what early-stage product-market fit really looks like.',
    bestFor: 'PMs who want inspiration and founder-level perspective.',
    tags: ['Founders', 'Origin stories', 'NPR'],
  },
];
---

<Base
  title="Podcasts — The Toolkit | AI Native PM"
  description="Put these on during your commute, workout, or afternoon walk — they compound quietly over time."
>
  <Nav />
  <ToolkitNav active="/toolkit/podcasts" />

  <main class="pt-[4.5rem] bg-warm-50">

    <!-- ── HERO ── -->
    <section class="bg-warm-100 border-b border-warm-200">
      <div class="max-w-4xl mx-auto px-6 py-12 sm:py-16">
        <div class="flex items-center gap-3 mb-5">
          <div class="h-px w-8 bg-craft-400"></div>
          <p class="text-xs font-bold uppercase tracking-widest text-warm-500">Ears-on learning</p>
        </div>
        <h1 class="font-serif-display text-3xl sm:text-4xl text-stone-900 mb-4 leading-tight tracking-tight">
          Podcasts
        </h1>
        <div class="w-14 h-1 bg-craft-400 rounded-full mb-5"></div>
        <p class="text-lg text-stone-500 max-w-2xl leading-relaxed">
          Put these on during your commute, workout, or afternoon walk — they compound quietly over time.
        </p>
      </div>
    </section>

    <div class="py-16 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="grid gap-5 stagger-children">
          {podcasts.map(({ name, host, frequency, description, bestFor, tags }) => (
            <div class="card-warm bg-warm-50 rounded-2xl border border-warm-200 p-7 hover:border-brand-200 transition-all duration-200 flex flex-col gap-4 animate-on-scroll">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="font-serif-display text-xl text-stone-900 mb-0.5">{name}</p>
                  <p class="text-stone-500 text-sm">Hosted by {host} · <span class="text-warm-500">{frequency}</span></p>
                </div>
                <div class="w-11 h-11 rounded-xl bg-brand-50 border border-brand-100 flex items-center justify-center flex-shrink-0 text-xl">
                  🎙️
                </div>
              </div>
              <p class="text-stone-600 leading-relaxed">{description}</p>
              <div class="border-t border-warm-200 pt-4">
                <p class="text-sm text-stone-500">
                  <span class="font-semibold text-stone-700">Best for: </span>{bestFor}
                </p>
              </div>
              <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <span class="text-xs bg-warm-100 text-stone-500 font-semibold px-2.5 py-1 rounded-full border border-warm-200">{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ── SECTION NAV ── -->
    <div class="bg-warm-100 border-t border-warm-200 py-8 px-6">
      <div class="max-w-6xl mx-auto flex justify-between">
        <a href="/toolkit/blogs" class="flex items-center gap-2 text-sm font-bold text-stone-500 hover:text-stone-900 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          Blogs
        </a>
        <a href="/toolkit" class="flex items-center gap-2 text-sm font-bold text-brand-700 hover:text-brand-900 transition-colors">
          Back to Toolkit
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>

    <!-- ── CTA ── -->
    <section class="bg-brand-900 py-14 px-6">
      <div class="max-w-2xl mx-auto text-center">
        <h3 class="font-serif-display text-2xl sm:text-3xl text-white mb-3">Want more PM insights?</h3>
        <p class="text-brand-200 mb-7 leading-relaxed">
          Get weekly articles on AI-native product management, from strategy to execution to surviving the AI transition.
        </p>
        <a href="/#newsletter" class="inline-block bg-white text-brand-800 font-bold px-8 py-3.5 rounded-xl hover:bg-warm-100 transition-colors">
          Join the Newsletter
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Base>
